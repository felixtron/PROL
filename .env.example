# ─────────────────────────────────────────────────────────────────────────────
# PROL - Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Database (PostgreSQL + pgvector)
DATABASE_URL="postgresql://prol:prol_dev_2026@localhost:5432/prol?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="localhost:3000"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_API_KEY=""

# Cloudflare Turnstile (CAPTCHA en sign-up / sign-in / forgot-password).
# Si ambas quedan vacías, el captcha NO se activa (login funciona normal) —
# útil para dev local. En prod, poner las llaves reales del dashboard de
# Cloudflare Turnstile. TURNSTILE_SITE_KEY se lee server-side y se pasa al
# cliente como prop (no es NEXT_PUBLIC; runtime-only, no requiere rebuild
# para rotar). Para tests locales, las llaves "always-pass" de Cloudflare:
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Stripe Connect
# IMPORTANT: NEVER commit real keys here. Use placeholders only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Cloudflare Stream (Video)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""

# AI (Claude API)
ANTHROPIC_API_KEY=""

# AssemblyAI (Transcription)
ASSEMBLYAI_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""
RESEND_DOMAIN=""

# Trigger.dev
TRIGGER_SECRET_KEY=""
