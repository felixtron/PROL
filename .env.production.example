# ─────────────────────────────────────────────────────────────────────────────
# PROL - Production environment variables
# Copy to .env on the VPS and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# --- App URL & Domain ---
APP_URL="https://prol.prosuite.pro"
APP_DOMAIN="prol.prosuite.pro"

# --- Database (used by docker-compose.prod.yml) ---
DB_USER="prol"
DB_PASSWORD="change_me_in_production"
DB_NAME="prol"

# --- Better Auth ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=""

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Cloudflare Stream (video hosting, optional) ---
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""

# --- Email (Resend) ---
RESEND_API_KEY=""
RESEND_DOMAIN="prosuite.pro"

# --- AI Module (optional - module 6) ---
ANTHROPIC_API_KEY=""
ASSEMBLYAI_API_KEY=""
TRIGGER_SECRET_KEY=""
