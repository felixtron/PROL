# Tolerancia ante red lenta o flaky desde el VPS al registry npm: vimos
# `ERR_SOCKET_TIMEOUT` colgando builds enteros en los últimos paquetes
# (Trigger.dev/OpenTelemetry). Estos defaults se aplican a npm y pnpm.
network-timeout=300000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
